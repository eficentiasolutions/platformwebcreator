generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Partner (cliente padre / course provider) ──

model Partner {
  id           String    @id @default(cuid())
  name         String
  templateType String    @default("generic")
  templateRepo String    @default("")
  description  String?
  active       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clients Client[]

  @@map("partners")
}

// ── Client (alumno / negocio que recibe una web) ──

model Client {
  id   String @id @default(cuid())
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Datos del negocio
  businessName String @default("")
  contactName  String @default("")
  email        String @default("")
  phone        String @default("")
  location     String @default("")
  province     String @default("")
  domain       String @default("")
  status       String @default("new")
  businessType String @default("")

  // Branding
  brandPrimaryColor  String @default("#0891B2")
  brandSecondaryColor String @default("#0E7490")
  brandAccentColor   String @default("#F59E0B")
  logoUrl            String @default("")
  heroImageUrl       String @default("")

  // Datos complejos como JSON
  services    Json @default("[]")
  zones       Json @default("[]")
  socialLinks Json @default("{}")

  // SEO
  seoTitle               String @default("")
  seoDescription         String @default("")
  seoKeywords            Json   @default("[]")
  googleSiteVerification String @default("")
  gAnalyticsId           String @default("")
  gscVerified            Boolean @default(false)

  // SEO Checklist (34 booleanos como JSON)
  seoChecklist Json @default("{}")

  // Onboarding
  onboardingStep     Int     @default(0)
  onboardingCompleted Boolean @default(false)

  // Notas
  notes String @default("")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

// ── App Settings (singleton) ──

model AppSetting {
  id              String  @id @default("singleton")
  activePartnerId String?

  @@map("app_settings")
}
